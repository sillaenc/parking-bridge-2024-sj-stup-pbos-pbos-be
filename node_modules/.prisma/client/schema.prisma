// PBOS migration schema (PostgreSQL) based on pb.yaml
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int     @id @default(autoincrement()) @map("uid")
  account     String  @db.VarChar(30)
  passwd      String
  username    String? @db.VarChar(50)
  userlevel   Int
  isActivated Boolean @default(true) @map("isActivated")

  @@unique([account])
  @@index([account, passwd])
  @@map("tb_users")
}

model Parking {
  id            Int      @id @default(autoincrement()) @map("uid")
  tag           String?  @db.VarChar(50)
  useTag        Boolean? @map("use_tag")
  logo          String?
  useLogo       Boolean? @map("use_logo")
  serverTimeout Int?     @map("server_timeout")

  @@map("tb_parking")
}

model LotType {
  id         Int      @id @default(autoincrement()) @map("uid")
  lotType    String?  @map("lot_type") @db.VarChar(30)
  tag        String?  @db.VarChar(30)
  codeFormat String?  @map("code_format") @db.VarChar(5)
  isUsed     Boolean?

  lots Lot[]

  @@index([lotType])
  @@index([isUsed])
  @@map("tb_lot_type")
}

model LotImage {
  id           Int      @id @default(autoincrement()) @map("uid")
  xbottomright Decimal? @db.Decimal(10, 2)
  ybottomright Decimal? @db.Decimal(10, 2)

  @@map("tb_lots_image")
}

model LotStatus {
  id       Int       @id @default(autoincrement()) @map("uid")
  lotId    Int?      @map("lot")
  isParked Boolean?
  added    DateTime?

  lot Lot? @relation(fields: [lotId], references: [id])

  @@index([added])
  @@map("tb_lot_status")
}

model DbSetting {
  id             Int     @id @default(autoincrement()) @map("uid")
  engineDbAddr   String? @map("engine_db_addr")
  engineDbId     String? @map("engine_db_id") @db.VarChar(20)
  engineDbPasswd String? @map("engine_db_passwd") @db.VarChar(20)
  displayDbLpr   String? @map("display_db_lpr")

  @@map("tb_db_setting")
}

model Lot {
  id        Int       @id @default(autoincrement()) @map("uid")
  tag       String?   @db.VarChar(50)
  lotTypeId Int?      @map("lot_type")
  point     String?   @db.VarChar(20)
  parked    Boolean?  @default(true)
  isUsed    Boolean?  @default(false)
  asset     String?
  floor     String?
  plate     String?
  startTime DateTime?

  lotType   LotType?      @relation(fields: [lotTypeId], references: [id])
  statuses  LotStatus[]
  processed ProcessedDb[]
  perDay    PerDay[]
  perMonth  PerMonth[]
  perYear   PerYear[]

  @@unique([tag])
  @@index([floor])
  @@index([tag])
  @@index([lotTypeId])
  @@map("tb_lots")
}

model ProcessedDb {
  id           Int       @id @default(autoincrement()) @map("uid")
  lotId        Int?      @map("lot")
  carType      Int?      @map("car_type")
  hourParking  Boolean?  @map("hour_parking")
  recordedHour DateTime? @map("recorded_hour")

  lot Lot? @relation(fields: [lotId], references: [id])

  @@index([recordedHour])
  @@index([lotId])
  @@map("processed_db")
}

model PerDay {
  id          Int       @id @default(autoincrement()) @map("uid")
  lotId       Int?      @map("lot")
  carType     Int?      @map("car_type")
  dayParking  Boolean?  @map("day_parking")
  recordedDay DateTime? @map("recorded_day")

  lot Lot? @relation(fields: [lotId], references: [id])

  @@index([recordedDay])
  @@map("perday")
}

model PerMonth {
  id            Int       @id @default(autoincrement()) @map("uid")
  lotId         Int?      @map("lot")
  carType       Int?      @map("car_type")
  monthParking  Boolean?  @map("month_parking")
  recordedMonth DateTime? @map("recorded_month")

  lot Lot? @relation(fields: [lotId], references: [id])

  @@index([recordedMonth])
  @@map("permonth")
}

model PerYear {
  id           Int       @id @default(autoincrement()) @map("uid")
  lotId        Int?      @map("lot")
  carType      Int?      @map("car_type")
  yearParking  Boolean?  @map("year_parking")
  recordedYear DateTime? @map("recorded_year")

  lot Lot? @relation(fields: [lotId], references: [id])

  @@index([recordedYear])
  @@map("peryear")
}

model ParkingZone {
  id          Int     @id @default(autoincrement()) @map("uid")
  parkingName String  @map("parking_name") @db.VarChar(50)
  fileAddress String  @map("file_address")
  floor       String?

  files ParkingZoneFile[]

  @@unique([parkingName])
  @@unique([fileAddress])
  @@index([parkingName])
  @@map("tb_parking_zone")
}

model ParkingSurface {
  id         Int    @id @default(autoincrement()) @map("uid")
  tag        String @db.VarChar(50)
  engineCode String @map("engine_code") @db.VarChar(10)
  uri        String

  @@index([tag])
  @@map("tb_parking_surface")
}

model RawData {
  uid        Int       @id @default(autoincrement()) @map("uid")
  recordId   Int?      @map("id")
  timestamp  DateTime?
  parkingLot String?   @map("parking_lot")

  @@map("rawdata")
}

model MultipleSigns {
  id         Int    @id @default(autoincrement()) @map("uid")
  parkingLot String @map("parking_lot")

  @@map("multiple_signs")
}

model BaseInfo {
  id          Int     @id @default(autoincrement()) @map("uid")
  name        String
  address     String
  latitude    String? @db.VarChar(30)
  longitude   String? @db.VarChar(30)
  manager     String
  phoneNumber String  @map("phone_number") @db.VarChar(30)

  @@map("base")
}

model Setting {
  id    Int     @id @default(autoincrement()) @map("uid")
  key   String  @unique
  value String?

  @@map("settings")
}

model Display {
  id        Int     @id @default(autoincrement()) @map("uid")
  tag       String  @unique
  lotTypeId Int?    @map("lot_type")
  point     String? @db.VarChar(20)
  asset     String?
  floor     String?

  @@map("display")
}

model Ping {
  id        Int      @id @default(autoincrement()) @map("uid")
  name      String
  address   String
  isalright Boolean?

  @@unique([name, address])
  @@map("ping")
}

model FileEntry {
  id               Int      @id @default(autoincrement()) @map("uid")
  filename         String   @db.VarChar(255)
  originalFilename String?  @map("original_filename") @db.VarChar(255)
  filePath         String   @map("file_path")
  fileType         String?  @map("file_type") @db.VarChar(10)
  fileCategory     String?  @map("file_category") @db.VarChar(20)
  fileSize         Int?     @map("file_size")
  mimeType         String?  @map("mime_type") @db.VarChar(100)
  description      String?
  uploadedAt       DateTime @default(now()) @map("uploaded_at")
  updatedAt        DateTime @default(now()) @map("updated_at")
  isActive         Boolean  @default(true) @map("is_active")

  parkingZoneFiles ParkingZoneFile[]

  @@unique([filePath])
  @@index([fileCategory])
  @@index([fileType])
  @@index([filename])
  @@index([isActive])
  @@map("tb_files")
}

model ParkingZoneFile {
  id            Int      @id @default(autoincrement()) @map("uid")
  parkingZoneId Int      @map("parking_zone_id")
  fileId        Int?     @map("file_id")
  filePurpose   String?  @map("file_purpose") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")

  parkingZone ParkingZone @relation(fields: [parkingZoneId], references: [id])
  file        FileEntry?  @relation(fields: [fileId], references: [id])

  @@unique([parkingZoneId, fileId])
  @@index([parkingZoneId])
  @@index([fileId])
  @@map("tb_parking_zone_files")
}

model Camera {
  id         Int     @id @default(autoincrement()) @map("uid")
  tag        String  @unique @db.VarChar(50)
  cameraName String  @map("camera_name") @db.VarChar(100)
  imageLink  String? @map("image_link") @db.VarChar(255)

  @@index([tag])
  @@map("tb_camera")
}

model RtspCapture {
  id            Int     @id @default(autoincrement()) @map("uid")
  tag           String  @unique @db.VarChar(50)
  rtspAddress   String  @map("rtsp_address")
  lastImagePath String? @map("last_image_path")

  @@index([tag])
  @@index([rtspAddress])
  @@map("rtsp_capture")
}
